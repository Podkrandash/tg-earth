{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/bot/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/textures/(.*)",
      "dest": "/public/textures/$1"
    },
    {
      "src": "/js/(.*)",
      "dest": "/public/js/$1"
    },
    {
      "src": "/(.*\\.js)",
      "dest": "/public/js/$1"
    },
    {
      "src": "/(.*\\.css)",
      "dest": "/public/css/$1"
    },
    {
      "src": "/(.*\\.(jpg|png))",
      "dest": "/public/textures/$1"
    },
    {
      "src": "/",
      "dest": "/public/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
} 