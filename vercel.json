{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "git": {
    "deploymentEnabled": true
  },
  "ignoreCommand": "git diff --quiet HEAD^ HEAD ./",
  "functions": {
    "api/server.js": {
      "memory": 1024,
      "maxDuration": 10
    }
  },
  "routes": [
    { "src": "/api/webhook", "dest": "/api/server" },
    { "src": "/js/(.*)", "dest": "/js/$1" },
    { "src": "/css/(.*)", "dest": "/css/$1" },
    { "src": "/textures/(.*)", "dest": "/textures/$1" },
    { "src": "/images/(.*)", "dest": "/images/$1" },
    { "src": "/(.*\\.(jpg|png|gif))", "dest": "/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
} 