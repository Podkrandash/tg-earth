{
  "version": 2,
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "outputDirectory": "public",
  "functions": {
    "server.js": {
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "/bot/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/textures/(.*)",
      "dest": "/textures/$1"
    },
    {
      "src": "/js/(.*)",
      "dest": "/js/$1"
    },
    {
      "src": "/(.*\\.js)",
      "dest": "/js/$1"
    },
    {
      "src": "/(.*\\.css)",
      "dest": "/css/$1"
    },
    {
      "src": "/(.*\\.(jpg|png))",
      "dest": "/textures/$1"
    },
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "crons": [
    {
      "path": "/bot/keepalive",
      "schedule": "*/1 * * * *"
    }
  ]
} 